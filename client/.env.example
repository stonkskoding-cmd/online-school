# =============================================================================
# Шаблон переменных окружения для client/
# Скопируйте: cp .env.example .env  (или copy .env.example .env на Windows)
# Файл .env не коммитится в git!
# =============================================================================

# --- API бэкенда ---
VITE_API_URL=https://online-school-backend-mqn9.onrender.com/api
VITE_SOCKET_URL=https://online-school-backend-mqn9.onrender.com

# --- Supabase Storage (обложки пакетов и материалы) ---
# Где взять:
#   1. https://supabase.com/dashboard → ваш проект
#   2. Project Settings → API
#   3. Project URL  → VITE_SUPABASE_URL
#   4. anon public key → VITE_SUPABASE_ANON_KEY
# Подробнее: README_SUPABASE.md в корне репозитория
#
# Нужны public buckets: packages, materials
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
