# Server (Render / локально)
PORT=5000
NODE_ENV=development

# PostgreSQL (Supabase pooler — порт 6543, для приложения И migrate deploy)
# DIRECT_URL (5432) не используется — Render не имеет доступа к direct port.
#
# Обязательные параметры в URL (код тоже добавит их, если забыли):
#   ?pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1

JWT_SECRET=change-me-long-random-string

# Админ-логин (/api/auth/admin-login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Фронтенд (CORS + Socket.IO в production)
FRONTEND_URL=https://your-frontend.onrender.com
CLIENT_URL=

# Публичный URL этого API (ссылки на локальные uploads, если Cloudinary не задан)
BACKEND_URL=https://your-api.onrender.com

# Cloudinary — загрузка обложек и файлов (папка dinastia-uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Опционально: ЮKassa, R2 — если используете
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
